<?xml version="1.0" encoding="UTF-8"?>
<!--
============================================
 WEB.CONFIG - Website Development Agency (WDA)
 IIS Server Configuration
============================================
-->
<configuration>
    <system.webServer>
        <!-- ============================================
             SEO: URL REWRITING
             ============================================ -->
        <rewrite>
            <rules>
                <!-- Force HTTPS -->
                <rule name="Force HTTPS" stopProcessing="true">
                    <match url="(.*)" />
                    <conditions>
                        <add input="{HTTPS}" pattern="^OFF$" />
                    </conditions>
                    <action type="Redirect" url="https://{HTTP_HOST}/{R:1}" redirectType="Permanent" />
                </rule>

                <!-- Remove trailing slash for non-directory URLs -->
                <rule name="Remove Trailing Slash" stopProcessing="true">
                    <match url="(.*)/$" />
                    <conditions>
                        <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
                        <add input="{REQUEST_FILENAME}" matchType="IsDirectory" negate="true" />
                    </conditions>
                    <action type="Redirect" url="{R:1}" redirectType="Permanent" />
                </rule>

                <!-- Redirect index.html to root -->
                <rule name="Redirect Index.html" stopProcessing="true">
                    <match url="^index\.html$" />
                    <action type="Redirect" url="/" redirectType="Permanent" />
                </rule>

                <!-- Ensure sitemap.xml is accessible -->
                <rule name="Sitemap Accessibility" stopProcessing="false">
                    <match url="^sitemap\.xml$" />
                    <action type="None" />
                </rule>

                <!-- Ensure robots.txt is accessible -->
                <rule name="Robots Accessibility" stopProcessing="false">
                    <match url="^robots\.txt$" />
                    <action type="None" />
                </rule>
            </rules>

            <outboundRules>
                <!-- Add canonical tag -->
                <rule name="Add Canonical Tag" preCondition="IsHTML">
                    <match serverVariable="RESPONSE_Link" pattern=".*" />
                    <action type="Rewrite" value="<{R:0}>; rel="canonical"" />
                </rule>
                <preConditions>
                    <preCondition name="IsHTML">
                        <add input="{RESPONSE_CONTENT_TYPE}" pattern="^text/html" />
                    </preCondition>
                </preConditions>
            </outboundRules>
        </rewrite>

        <!-- ============================================
             CACHING: STATIC CONTENT
             ============================================ -->
        <caching>
            <profiles>
                <!-- HTML - 1 week -->
                <add extension=".html" policy="CacheUntilTime" kernelCachePolicy="CacheUntilTime" duration="7.00:00:00" />
                <add extension=".htm" policy="CacheUntilTime" kernelCachePolicy="CacheUntilTime" duration="7.00:00:00" />

                <!-- CSS & JS - 1 year -->
                <add extension=".css" policy="CacheUntilTime" kernelCachePolicy="CacheUntilTime" duration="365.00:00:00" />
                <add extension=".js" policy="CacheUntilTime" kernelCachePolicy="CacheUntilTime" duration="365.00:00:00" />

                <!-- Images - 1 year -->
                <add extension=".jpg" policy="CacheUntilTime" kernelCachePolicy="CacheUntilTime" duration="365.00:00:00" />
                <add extension=".jpeg" policy="CacheUntilTime" kernelCachePolicy="CacheUntilTime" duration="365.00:00:00" />
                <add extension=".png" policy="CacheUntilTime" kernelCachePolicy="CacheUntilTime" duration="365.00:00:00" />
                <add extension=".gif" policy="CacheUntilTime" kernelCachePolicy="CacheUntilTime" duration="365.00:00:00" />
                <add extension=".webp" policy="CacheUntilTime" kernelCachePolicy="CacheUntilTime" duration="365.00:00:00" />
                <add extension=".svg" policy="CacheUntilTime" kernelCachePolicy="CacheUntilTime" duration="365.00:00:00" />
                <add extension=".ico" policy="CacheUntilTime" kernelCachePolicy="CacheUntilTime" duration="365.00:00:00" />

                <!-- Fonts - 1 year -->
                <add extension=".woff" policy="CacheUntilTime" kernelCachePolicy="CacheUntilTime" duration="365.00:00:00" />
                <add extension=".woff2" policy="CacheUntilTime" kernelCachePolicy="CacheUntilTime" duration="365.00:00:00" />
                <add extension=".ttf" policy="CacheUntilTime" kernelCachePolicy="CacheUntilTime" duration="365.00:00:00" />
                <add extension=".otf" policy="CacheUntilTime" kernelCachePolicy="CacheUntilTime" duration="365.00:00:00" />
                <add extension=".eot" policy="CacheUntilTime" kernelCachePolicy="CacheUntilTime" duration="365.00:00:00" />

                <!-- Sitemap & Robots - 1 day -->
                <add extension=".xml" policy="CacheUntilTime" kernelCachePolicy="CacheUntilTime" duration="1.00:00:00" />
            </profiles>
        </caching>

        <!-- ============================================
             COMPRESSION: STATIC & DYNAMIC
             ============================================ -->
        <urlCompression doStaticCompression="true" doDynamicCompression="true" />
        <httpCompression>
            <dynamicTypes>
                <add mimeType="text/*" enabled="true" />
                <add mimeType="application/javascript" enabled="true" />
                <add mimeType="application/json" enabled="true" />
                <add mimeType="image/svg+xml" enabled="true" />
                <add mimeType="font/*" enabled="true" />
            </dynamicTypes>
            <staticTypes>
                <add mimeType="text/*" enabled="true" />
                <add mimeType="application/javascript" enabled="true" />
                <add mimeType="application/json" enabled="true" />
                <add mimeType="image/svg+xml" enabled="true" />
                <add mimeType="font/*" enabled="true" />
                <add mimeType="application/x-font*" enabled="true" />
            </staticTypes>
        </httpCompression>

        <!-- ============================================
             SECURITY HEADERS
             ============================================ -->
        <httpProtocol>
            <customHeaders>
                <!-- Security Headers -->
                <add name="X-XSS-Protection" value="1; mode=block" />
                <add name="X-Content-Type-Options" value="nosniff" />
                <add name="X-Frame-Options" value="SAMEORIGIN" />
                <add name="Referrer-Policy" value="strict-origin-when-cross-origin" />
                <add name="Permissions-Policy" value="geolocation=(), microphone=(), camera=()" />

                <!-- Cache Control Headers -->
                <add name="Cache-Control" value="public, max-age=31536000" />

                <!-- Sitemap CORS (allow search engines) -->
                <add name="Access-Control-Allow-Origin" value="*" />
            </customHeaders>
        </httpProtocol>

        <!-- ============================================
             STATIC CONTENT
             ============================================ -->
        <staticContent>
            <!-- MIME Types -->
            <remove fileExtension=".webp" />
            <mimeMap fileExtension=".webp" mimeType="image/webp" />
            <remove fileExtension=".woff" />
            <mimeMap fileExtension=".woff" mimeType="font/woff" />
            <remove fileExtension=".woff2" />
            <mimeMap fileExtension=".woff2" mimeType="font/woff2" />
            <remove fileExtension=".js" />
            <mimeMap fileExtension=".js" mimeType="application/javascript" />
            <remove fileExtension=".json" />
            <mimeMap fileExtension=".json" mimeType="application/json" />
            <remove fileExtension=".xml" />
            <mimeMap fileExtension=".xml" mimeType="application/xml" />
            
            <!-- Enable caching for sitemap.xml -->
            <clientCache cacheControlMode="UseMaxAge" cacheControlMaxAge="1.00:00:00" />
        </staticContent>

        <!-- ============================================
             DIRECTORY BROWSING
             ============================================ -->
        <directoryBrowse enabled="false" />

        <!-- ============================================
             DEFAULT DOCUMENTS
             ============================================ -->
        <defaultDocument enabled="true">
            <files>
                <clear />
                <add value="index.html" />
                <add value="index.htm" />
                <add value="default.html" />
                <add value="default.htm" />
            </files>
        </defaultDocument>

        <!-- ============================================
             ERROR PAGES
             ============================================ -->
        <httpErrors errorMode="Custom" existingResponse="Replace">
            <remove statusCode="404" />
            <error statusCode="404" path="/404.html" responseMode="Redirect" />
            <remove statusCode="500" />
            <error statusCode="500" path="/500.html" responseMode="Redirect" />
            <remove statusCode="403" />
            <error statusCode="403" path="/403.html" responseMode="Redirect" />
        </httpErrors>
    </system.webServer>
</configuration>